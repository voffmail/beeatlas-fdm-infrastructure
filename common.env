
# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/fdm_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# RabbitMQ
SPRING_RABBITMQ_VIRTUAL_HOST=/
SPRING_RABBITMQ_HOST=fdm-rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

# Neo4j
SPRING_NEO4J_URI=bolt://neo4j:7687
SPRING_NEO4J_AUTHENTICATION_USERNAME=neo4j
SPRING_NEO4J_AUTHENTICATION_PASSWORD=password

# Redis (shared)
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=redis-password

# Authentik
AUTHENTIK_HOST=http://authentik-server:9000
AUTHENTIK_SECRET_KEY=my-strong-secret-key
INTEGRATION_AUTHENTIC_AUTH_URL=http://authentik-server:9000/application/o/test/

# S3
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY=minioadmin
AWS_S3_SECRET_KEY=minioadmin
AWS_S3_ENDPOINT=http://document-service-minio:9000
AWS_S3_BUCKET_NAME=document-service-documents

# Gateway/frontend URLs (shared)
